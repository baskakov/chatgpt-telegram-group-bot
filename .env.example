# Telegram Bot token (from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# OpenAI API key
OPENAI_API_KEY=your_openai_api_key_here

# ChatGPT model to use (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# DALL·E model to use (default: dall-e-3)
IMAGE_MODEL=dall-e-3

# System prompt — defines bot personality and response style (optional)
# If not set, the default prompt with emoji formatting is used
SYSTEM_PROMPT=

# Extra instructions appended to the system prompt (optional)
# Use this to add context without overriding the default formatting rules
# Example: SYSTEM_PROMPT_EXTRA=Ты специалист по финансам. Отвечай только на темы инвестиций.
SYSTEM_PROMPT_EXTRA=

# ── Scheduler ─────────────────────────────────────────────────────────────────

# Enable or disable the daily scheduler (true / false)
SCHEDULER_ENABLED=false

# Cron expression for the scheduler in UTC (default: every day at 07:00 UTC)
# Format: minute hour day month weekday
SCHEDULER_CRON=0 7 * * *

# Question sent to every whitelisted group on schedule
SCHEDULER_QUESTION=Какие интересные события в мире происходили в сегодняшний день в прошлом? Расскажи кратко о 5 самых интересных фактах.

# Comma-separated list of allowed Telegram user IDs for private chats
# Example: 123456789,987654321
WHITELIST_USER_IDS=

# Comma-separated list of allowed Telegram group/supergroup chat IDs
# Example: -1001234567890,-1009876543210
WHITELIST_GROUP_IDS=

